# .env.example — copy to .env for local development
# On fly.io these are set via: fly secrets set APP_PASSWORD="..." SECRET_KEY="..."
# NEVER commit .env to git

# The password Josefina uses to log in
APP_PASSWORD=changeme

# Random hex string — generate once with: python -c "import secrets; print(secrets.token_hex(32))"
# Must stay the same across restarts or sessions will be invalidated
SECRET_KEY=replace_with_64_char_hex_string
