# Copy this file to .env and fill in your values.
# Never commit .env to git - it is in .gitignore.
# See DEPLOYMENT_SECURITY.md for full security guidance.

# ---------------------------------------------------------------------------
# LLM Provider (optional - Rell is fully deterministic without these)
# ---------------------------------------------------------------------------

# Which LLM provider to use by default (none | openai | claude | ollama)
# Override at CLI with: python run_audit.py --llm ollama
RELL_LLM_PROVIDER=none

# Override the default model for the selected provider
# Defaults: openai=gpt-4o  claude=claude-3-5-sonnet-20241022  ollama=llama3
# RELL_LLM_MODEL=mistral

# Cloud LLM API keys (only needed if RELL_LLM_PROVIDER=openai or claude)
# WARNING: When using cloud LLMs, finding summaries are sent externally.
# See DEPLOYMENT_SECURITY.md section LLM Data Exposure before enabling.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama base URL (only if Ollama is NOT running on localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Database credentials (alternative to CLI flags)
# See DEPLOYMENT_SECURITY.md section Credential Management for all options.
# Format: DB_CONN_NICKNAME=SQLAlchemy connection string
# Use a READ-ONLY database user - never sa or admin accounts.
# ---------------------------------------------------------------------------
# DB_CONN_MY_DATABASE=mssql+pyodbc://rell_audit:password@server/db?driver=ODBC+Driver+17+for+SQL+Server
# DB_CONN_POSTGRES_DW=postgresql+psycopg2://rell_audit:password@host:5432/warehouse
